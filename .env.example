# Copy to .env for docker-compose or local production-style runs.

# development | production
CHEMISTRY_APP_ENV=development

# Postgres runtime storage. In production this must be explicit.
DATA_BACKEND=postgres
DATABASE_URL=postgresql+psycopg://chemistry:chemistry@postgres:5432/chemistry_exam
RUN_DB_CHECK_ON_STARTUP=false
# Docker Compose exposes Postgres to the host on 15432 by default to avoid
# colliding with a developer's local Postgres on 5432. Containers still use
# postgres:5432 through the Compose network.
POSTGRES_HOST_BIND=127.0.0.1
POSTGRES_HOST_PORT=15432

# Local media storage for uploaded videos/resources.
MEDIA_ROOT=/app/data/media
MAX_MEDIA_UPLOAD_MB=1024
TUS_UPLOAD_DIR=tus
TUS_PUBLIC_ENDPOINT=http://127.0.0.1:10980/files/
VIDEO_WORKER_POLL_SECONDS=5
VIDEO_WORKER_ID=local-video-worker
VIDEO_LEARNING_MAX_WIDTH=1280
VIDEO_LEARNING_CRF=24
VIDEO_LEARNING_MAX_FPS=30
VIDEO_LEARNING_TRANSCODE_THRESHOLD_MB=300
VIDEO_SIMILARITY_ALGORITHM=vpdq-threatexchange-1.2.16
VIDEO_SIMILARITY_COMMAND=python -m server.app.video_similarity vpdq-signature "{input}" "{output}"
VIDEO_SIMILARITY_COMPARE_COMMAND=python -m server.app.video_similarity vpdq-compare "{current}" "{candidate}"
VIDEO_SIMILARITY_THRESHOLD=0.86
VIDEO_VPDQ_SECONDS_PER_HASH=1

# Public API origin shown to web clients.
API_PUBLIC_BASE_URL=http://127.0.0.1:8000
FRONTEND_ALLOWED_ORIGINS=http://222.200.189.249:5173,http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:5175,http://127.0.0.1:5175
STUDENT_PREVIEW_APP_BASE_URL=http://222.200.189.249:5173
STUDENT_PREVIEW_ALLOWED_ORIGINS=http://222.200.189.249:5173,http://localhost:5173,http://127.0.0.1:5173
STUDENT_PREVIEW_TICKET_EXPIRE_MINUTES=10
STUDENT_PREVIEW_SESSION_EXPIRE_MINUTES=240
WEB_STUDENT_HOST_BIND=222.200.189.249
WEB_STUDENT_HOST_PORT=5173
WEB_TEACHER_HOST_BIND=127.0.0.1
WEB_TEACHER_HOST_PORT=5174
WEB_ADMIN_HOST_BIND=127.0.0.1
WEB_ADMIN_HOST_PORT=5175

# Auth. Use a long random value in production.
AUTH_SECRET_KEY=dev-only-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=720
# web-admin uses this config token directly instead of an app_users login.
# Production must replace it with a long random value.
WEB_ADMIN_ACCESS_TOKEN=dev-only-web-admin-token-change-me

# Hybrid RAG/BGE. Enable the rag Docker Compose profile when RAG_HYBRID_BGE_ENABLED=true.
# Core chunks/embeddings import from data/seed; CHEMISTRY_RAG_ROOT is only for optional source image assets.
RAG_HYBRID_BGE_ENABLED=true
RAG_QUERY_GENERATION_ENABLED=true
RAG_BGE_SERVICE_URL=http://bge-rag:8010
RAG_BGE_TIMEOUT_SECONDS=60
RAG_KEYWORD_TOP_K=16
RAG_VECTOR_TOP_K=24
RAG_RERANK_TOP_K=9
RAG_FINAL_TOP_K=5
CHEMISTRY_RAG_ROOT=/chemistry-rag

# Agent/LLM. Use disabled for deterministic local fallback until a provider is configured.
AGENT_LLM_PROVIDER=disabled
AGENT_LLM_BASE_URL=
AGENT_LLM_API_KEY=
AGENT_LLM_MODEL=

# Student experiment video-library search.
# Production must use Elasticsearch with IK analysis and must not enable local fallback.
VIDEO_LIBRARY_SEARCH_ENABLED=true
VIDEO_LIBRARY_SEARCH_BACKEND=elasticsearch
VIDEO_LIBRARY_SEARCH_URL=http://elasticsearch:9200
VIDEO_LIBRARY_SEARCH_INDEX=student-video-library
VIDEO_LIBRARY_SEARCH_ANALYZER=ik_max_word
VIDEO_LIBRARY_SEARCH_BOOTSTRAP_INDEX=true
VIDEO_LIBRARY_SEARCH_TIMEOUT_SECONDS=3
VIDEO_LIBRARY_SEARCH_LOCAL_FALLBACK=true
VIDEO_LIBRARY_SEARCH_REQUIRE_ES_IN_PRODUCTION=true
ELASTICSEARCH_HOST_BIND=127.0.0.1
ELASTICSEARCH_HOST_PORT=9200

# Compatibility with the existing RAG implementation.
OPENAI_API_KEY=
OPENAI_MODEL=
LLM_API_KEY=
LLM_MODEL=
